# Supabase (Settings -> API in your Supabase project)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Free LLM — Google Gemini (get a free key: https://aistudio.google.com/apikey)
GEMINI_API_KEY=
# Optional: override the model (default: gemini-2.5-flash)
LLM_MODEL=
# Optional, paid — only needed if an agent is configured (via the panel's
# Agent Settings) to use Claude or OpenAI instead of the free Gemini default.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Google service account for GSC + GA4 (paste the full JSON as one line)
GOOGLE_SERVICE_ACCOUNT_JSON=

# Email notifications (free, via Gmail SMTP — needs a Gmail "App Password", not your normal password)
GMAIL_USER=
GMAIL_APP_PASSWORD=
# Comma-separated list of who should receive notifications
NOTIFY_EMAILS=

# Slack Approve/Reject notifications
SLACK_WEBHOOK_URL=
# Must match the APPROVE_SECRET set on the Supabase Edge Function (supabase secrets set)
APPROVE_SECRET=
